{
  "kind": "collectionType",
  "collectionName": "gift_cards",
  "info": {
    "singularName": "gift-card",
    "pluralName": "gift-cards",
    "displayName": "Gift Card"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "card_region": {
      "type": "enumeration",
      "enum": [
        "EUROPE",
        "UNITED STATES",
        "GLOBAL",
        "RUSSIA",
        "UNITED KINGDOM",
        "CHINA",
        "ROW (REST OF WORLD)",
        "LATIN AMERICA",
        "ASIA",
        "GERMANY",
        "AUSTRALIA",
        "BRAZIL",
        "INDIA",
        "JAPAN",
        "NORTH AMERICA",
        "POLAND",
        "TURKEY",
        "HONG KONG",
        "TAIWAN",
        "VIETNAM",
        "THAILAND",
        "SOUTH KOREA",
        "ARGENTINA",
        "CANADA",
        "DENMARK",
        "SWEDEN"
      ]
    },
    "price": {
      "type": "decimal"
    },
    "discountPrice": {
      "type": "decimal"
    },
    "notice": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "descriptionkey": {
      "type": "richtext"
    },
    "publisher": {
      "type": "string"
    },
    "developer": {
      "type": "string"
    },
    "releaseDate": {
      "type": "date"
    },
    "minimumRequirement": {
      "type": "component",
      "component": "game-requirements.minimum",
      "repeatable": false
    },
    "recommendedRequirement": {
      "type": "component",
      "component": "game-requirements.recommended",
      "repeatable": false
    },
    "audio_language": {
      "type": "component",
      "component": "game-language.audio-language",
      "repeatable": false
    },
    "interface_language": {
      "type": "component",
      "component": "game-language.interface-language",
      "repeatable": false
    },
    "subtitles_language": {
      "type": "component",
      "component": "game-language.subtitles-language",
      "repeatable": false
    },
    "game_tag_seo": {
      "type": "component",
      "component": "slug-seo-tag.tag",
      "repeatable": false
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "age": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "platform": {
      "type": "enumeration",
      "enum": [
        "psn",
        "xbox",
        "steam",
        "spotify",
        "roblox",
        "binance"
      ]
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "gift-card",
        "game",
        "subscription"
      ]
    },
    "workPlatform": {
      "type": "enumeration",
      "enum": [
        "Windows",
        "Steam",
        "Epic Game",
        "Xbox",
        "PlayStation"
      ]
    },
    "item_type": {
      "type": "enumeration",
      "default": "GIFT CARD",
      "enum": [
        "GAME",
        "SOFTWARE",
        "GIFT CARD",
        "GAME DLC",
        "GAME POINTS",
        "DLC"
      ]
    },
    "item": {
      "type": "enumeration",
      "default": "DIGITAL KEY",
      "enum": [
        "DIGITAL KEY"
      ]
    },
    "editiondescription": {
      "type": "richtext"
    },
    "Available": {
      "type": "boolean",
      "default": true
    },
    "platform_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "relatedProducts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::gift-card.gift-card"
    },
    "var_title": {
      "type": "string"
    }
  }
}
